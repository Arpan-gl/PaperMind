# ── PaperMind Environment Variables ──
# See docs/architecture.md for details

OPENROUTER_API_KEY=sk-or-...
COGNEE_DB_PATH=./cognee_db
KUZU_DB_PATH=./kuzu_graph
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000
PAPERMIND_EMBEDDING_URL=http://127.0.0.1:8001
PAPERMIND_EMBEDDING_MODEL=all-MiniLM-L6-v2
SENTENCE_TRANSFORMERS_HOME=./hf_cache
HF_HOME=./hf_cache
PAPERMIND_ENABLE_GAP_SYNTHESIS=false
PAPERMIND_GAP_SYNTHESIS_TIMEOUT_SECONDS=20
